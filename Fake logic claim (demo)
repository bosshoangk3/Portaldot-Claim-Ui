import { useState } from "react";
import { Button } from "@/components/ui/button";
import { Card, CardContent } from "@/components/ui/card";

export default function ClaimPortalDot() {
  const [wallet, setWallet] = useState(null);
  const [status, setStatus] = useState("Not connected");

  const connectWallet = async () => {
    if (window.ethereum) {
      try {
        const accounts = await window.ethereum.request({
          method: "eth_requestAccounts",
        });
        setWallet(accounts[0]);
        setStatus("Wallet Connected");
      } catch (err) {
        setStatus("Connection Failed");
      }
    } else {
      setStatus("Install MetaMask");
    }
  };

  const claimToken = async () => {
    if (!wallet) {
      setStatus("Connect wallet first");
      return;
    }

    try {
      // Fake claim logic (demo only)
      setStatus("Processing claim...");

      await new Promise((res) => setTimeout(res, 2000));

      setStatus("Claim successful (demo)");
    } catch (err) {
      setStatus("Claim failed");
    }
  };

  return (
    <div className="min-h-screen flex items-center justify-center bg-black text-white">
      <Card className="w-[350px] rounded-2xl shadow-xl bg-zinc-900">
        <CardContent className="p-6 space-y-4">
          <h1 className="text-xl font-bold">Portaldot Airdrop</h1>
          <p className="text-sm text-gray-400">
            Claim your POT tokens from the early supporter program.
          </p>

          <div className="text-xs break-all">
            Wallet: {wallet || "Not connected"}
          </div>

          <div className="text-xs text-green-400">Status: {status}</div>

          <Button onClick={connectWallet} className="w-full">
            Connect Wallet
          </Button>

          <Button
            onClick={claimToken}
            className="w-full bg-green-600 hover:bg-green-700"
          >
            Claim POT
          </Button>
        </CardContent>
      </Card>
    </div>
  );
}
